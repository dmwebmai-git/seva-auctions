# ------------------------------------------------------------------
# Seva Auctions - Environment Variables Template
# ------------------------------------------------------------------
# Copy this file to ".env" and fill in the real values.
# NEVER commit the real ".env" file to GitHub - it holds secrets.
# On Railway, add these same names under your Web service > Variables.
# See the migration guide (Step 7) for what each value should be.
# ------------------------------------------------------------------

# --- Database (from Railway PostgreSQL > Variables) ---
DATABASE_URL="postgresql://user:password@host:port/database"

# --- Website address & login security ---
# On Railway use your temporary railway.app address first,
# then change to https://www.sevaauctions.com at go-live.
NEXTAUTH_URL="https://your-app.up.railway.app"
# IMPORTANT: keep this the EXACT same value as your current setup,
# or every user gets logged out.
NEXTAUTH_SECRET="your-existing-nextauth-secret"

# --- File storage (Cloudflare R2) ---
AWS_BUCKET_NAME="seva-auctions-files"
AWS_FOLDER_PREFIX=""
AWS_REGION="auto"
AWS_ACCESS_KEY_ID="your-r2-access-key-id"
AWS_SECRET_ACCESS_KEY="your-r2-secret-access-key"
AWS_ENDPOINT_URL="https://<your-account-id>.r2.cloudflarestorage.com"
FILE_PUBLIC_BASE_URL="https://pub-xxxxxxxx.r2.dev"

# --- Payments (Stripe) ---
STRIPE_PUBLISHABLE_KEY="pk_live_or_test_..."
STRIPE_SECRET_KEY="sk_live_or_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Scheduled job (auto-close auctions) ---
# A long random password you invent; must match in the Cron service.
CRON_SECRET="make-a-long-random-string-here"

# --- Emails & AI features (Abacus AI) ---
ABACUSAI_API_KEY="your-existing-abacusai-api-key"
WEB_APP_ID="your-existing-web-app-id"
NOTIF_ID_AUCTION_WON="your-existing-value"
NOTIF_ID_OUTBID_ALERT="your-existing-value"
NOTIF_ID_NEW_SALE_ALERT="your-existing-value"
NOTIF_ID_PAYMENT_CONFIRMATION="your-existing-value"
